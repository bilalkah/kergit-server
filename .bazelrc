# === SSL + QUIC + LIBDEFLATE (Debug build) ===
build:sslquic_dbg --define USE_SSL=true
build:sslquic_dbg --define WITH_BORINGSSL=1
build:sslquic_dbg --define WITH_QUIC=1
build:sslquic_dbg --define WITH_LIBDEFLATE=1
build:sslquic_dbg -c dbg
build:sslquic_dbg --strip=never

# === SSL + QUIC + LIBDEFLATE (Fastbuild) ===
build:sslquic_fast --define USE_SSL=true
build:sslquic_fast --define WITH_BORINGSSL=1
build:sslquic_fast --define WITH_QUIC=1
build:sslquic_fast --define WITH_LIBDEFLATE=1
build:sslquic_fast -c fastbuild

# === SSL + QUIC + LIBDEFLATE (Release/Opt) ===
build:sslquic_opt --define USE_SSL=true
build:sslquic_opt --define WITH_BORINGSSL=1
build:sslquic_opt --define WITH_QUIC=1
build:sslquic_opt --define WITH_LIBDEFLATE=1
build:sslquic_opt -c opt
build:sslquic_opt --strip=always

# === disable SSL + QUIC + LIBDEFLATE ===
build:vanilla --define WITH_BORINGSSL=0
build:vanilla --define WITH_QUIC=0
build:vanilla --define WITH_LIBDEFLATE=0
build:vanilla --define USE_SSL=false
build:vanilla -c opt
build:vanilla --strip=always
build:vanilla --cxxopt=-std=c++23
build:vanilla --host_cxxopt=-std=c++23
build:vanilla --action_env=CC=/usr/bin/gcc-13
build:vanilla --action_env=CXX=/usr/bin/g++-13
build:vanilla --host_action_env=CC=/usr/bin/gcc-13
build:vanilla --host_action_env=CXX=/usr/bin/g++-13
build:vanilla --cxxopt=-std=gnu++23
build:vanilla --host_cxxopt=-std=gnu++23

# build:vanilla --action_env=CC=clang
# build:vanilla --action_env=CXX=clang++
# build:vanilla --host_action_env=CC=clang
# build:vanilla --host_action_env=CXX=clang++
# build:vanilla --action_env=CCACHE_DISABLE=1
# build:vanilla --repo_env=CC=/usr/bin/clang
# build:vanilla --repo_env=CXX=/usr/bin/clang++
# build:vanilla --action_env=CC=/usr/bin/clang
# build:vanilla --action_env=CXX=/usr/bin/clang++
# build:vanilla --host_action_env=CC=/usr/bin/clang
# build:vanilla --host_action_env=CXX=/usr/bin/clang++


# === disable SSL + QUIC + LIBDEFLATE ===
build:vanilla_dbg --define WITH_BORINGSSL=0
build:vanilla_dbg --define WITH_QUIC=0
build:vanilla_dbg --define WITH_LIBDEFLATE=0
build:vanilla_dbg --define USE_SSL=false
build:vanilla_dbg -c dbg
build:vanilla_dbg --strip=never
build:vanilla_dbg --cxxopt=-std=c++23
build:vanilla_dbg --host_cxxopt=-std=c++23
build:vanilla_dbg --action_env=CC=/usr/bin/gcc-13
build:vanilla_dbg --action_env=CXX=/usr/bin/g++-13
build:vanilla_dbg --host_action_env=CC=/usr/bin/gcc-13
build:vanilla_dbg --host_action_env=CXX=/usr/bin/g++-13
build:vanilla_dbg --cxxopt=-std=gnu++23
build:vanilla_dbg --host_cxxopt=-std=gnu++23

# === configurations for tests ===
test:testing -c dbg
test:testing --test_output=all
test:testing --verbose_failures
test:testing --nocache_test_results