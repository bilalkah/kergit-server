cc_library(
    name = "uwebsockets",
    srcs = [
        "capi/libuwebsockets.cpp"
    ],
    hdrs = glob([
        "src/*.h",
        "capi/libuwebsockets.h"
    ]) + ["@usockets//:usockets"],
    includes = ["src", "capi", "@usockets//:src", "."],
