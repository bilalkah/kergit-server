# Copy this file to `.env` and replace every placeholder before running the full stack.
# Never commit real secrets, certificates, or production-only hostnames.

# -----------------------------------------------------------------------------
# Public app URLs
# -----------------------------------------------------------------------------
WEB_DOMAIN="https://localhost"

# -----------------------------------------------------------------------------
# Caddy / ingress
# -----------------------------------------------------------------------------
CADDY_TLS_CERT_FILE="/certs/dev/localhost.pem"
CADDY_TLS_KEY_FILE="/certs/dev/localhost-key.pem"

# -----------------------------------------------------------------------------
# Realtime server / control plane
# -----------------------------------------------------------------------------
LISTEN_HOST="0.0.0.0"
SOCKET_PORT="9001"
SOCKET_PATTERN="/*"
WS_ORIGIN_POLICY_PATH="config/ws_origin_policy.yaml"
CONTROL_HOST="0.0.0.0"
CONTROL_PORT="8081"

# Optional tuning
MAX_CONNECTIONS="255"
MAX_MESSAGE_SIZE="262144"
OUTBOUND_QUEUE_CAPACITY="50000"
WORKER_THREADS="3"
MAX_SESSIONS_PER_USER="0"
EVENT_QUEUE_CAPACITY="30000"
DB_WRITE_QUEUE_CAPACITY="10000"
DB_WRITE_MAX_RETRIES="3"
DB_WRITE_RETRY_MS="25"
LOG_DIR="logs"
METRICS_LOG="0"

# -----------------------------------------------------------------------------
# PostgreSQL / Supabase database
# -----------------------------------------------------------------------------
DB_ENGINE="postgresql"
DB_HOST="your-pooler-host.supabase.com"
DB_PORT=5432
DB_NAME="postgres"
DB_USER="postgres.your-project-ref"
DB_PASSWORD="replace-with-database-password"
DB_SSL=1
DB_SSL_ROOT_CERT="certs/database/root.crt"
DB_READ_POOL_SIZE=1
DB_WRITE_POOL_SIZE=1

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST="redis-node"
REDIS_PORT="6379"

# -----------------------------------------------------------------------------
# Supabase auth / storage
# -----------------------------------------------------------------------------
# Use the audience for your own Supabase project.
SUPABASE_EXPECTED_AUD="authenticated"

# Paste your own complete JWK JSON payloads here.
SUPABASE_JWT_CURRENT_KEY='replace-with-current-project-jwk-json'
SUPABASE_JWT_STANDBY_KEY='replace-with-standby-project-jwk-json'

NUXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NUXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
# Private server-only secret for HMAC-SHA256 of normalized emails used by the
# deleted-account email reservation (account deletion / signup precheck).
# Use a long random value. Never expose to public/browser runtime config.
ACCOUNT_EMAIL_HASH_SECRET="replace-with-a-long-random-account-email-hash-secret"
SUPABASE_ATTACHMENTS_BUCKET="chat-attachments"
SUPABASE_ATTACHMENT_SIGN_TTL_SEC=300

# Chat attachment / link-preview limits
CHAT_ATTACHMENT_MAX_FILES="6"
CHAT_ATTACHMENT_MAX_SIZE_BYTES="15728640"
CHAT_LINK_PREVIEW_TIMEOUT_MS="3000"
CHAT_LINK_PREVIEW_CACHE_TTL_SEC="900"
CHAT_LINK_PREVIEW_MAX_HEAD_BYTES="262144"
CHAT_LINK_PREVIEW_MAX_OEMBED_BYTES="131072"
CHAT_LINK_PREVIEW_MAX_REDIRECTS="3"
CHAT_LINK_PREVIEW_CACHE_MAX_ENTRIES="1000"

# -----------------------------------------------------------------------------
# LiveKit
# -----------------------------------------------------------------------------
# These must match the `keys` section in your LiveKit YAML files.
LIVEKIT_API_KEY="replace-with-livekit-api-key"
LIVEKIT_API_SECRET="replace-with-livekit-api-secret"
LIVEKIT_WEBHOOK_URL="http://server-node:8080/webhook"

# Defines every Compose-managed LiveKit node. Production requires a valid node_ip per entry.
LIVEKIT_NODES='[{"id":"livekit-a","signal_port":7880,"rtc_tcp_port":7881,"rtc_udp_start":50000,"rtc_udp_end":50100,"prometheus_port":6789,"node_ip":"127.0.0.1"},{"id":"livekit-b","signal_port":7890,"rtc_tcp_port":7891,"rtc_udp_start":50101,"rtc_udp_end":50200,"prometheus_port":6790,"node_ip":"127.0.0.1"}]'

# Voice key / reconcile tuning
LIVEKIT_RECONCILE_INTERVAL_SEC="10"
LIVEKIT_MISSING_CLEAR_SEC="60"
VOICE_E2EE_STORAGE_SECRET="replace-with-64-character-hex-secret"
VOICE_E2EE_KEY_TTL_SEC="86400"
VOICE_E2EE_REKEY_GUARD_SEC="60"

# -----------------------------------------------------------------------------
# Web admin app
# -----------------------------------------------------------------------------
NUXT_ADMIN_APP_BASE_URL="/admin/"
NUXT_PUBLIC_ADMIN_METRICS_BASE="/admin-api"
NUXT_PUBLIC_ADMIN_LIVEKIT_METRICS_BASE="/admin-livekit-metrics"
ADMIN_ALLOWED_CIDR="127.0.0.1/32"

ADMIN_METRICS_PROXY_TARGET="http://host.docker.internal:8081"
ADMIN_LIVEKIT_PROXY_HOST="host.docker.internal"
