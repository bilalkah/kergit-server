(livekit_cors_headers) {
  Access-Control-Allow-Origin "{http.request.header.Origin}"
  Access-Control-Allow-Credentials "true"
  Access-Control-Allow-Methods "GET, OPTIONS"
  Access-Control-Allow-Headers "Authorization, Content-Type, X-Room-ID"
  Vary "Origin"
}

kergit.com {
  tls /certs/cert.pem /certs/key.pem
  
  @livekitAllowedPreflight {
    path /livekit*
    method OPTIONS
    # Keep this allowlist aligned with config/ws_origin_policy.yaml.
    expression `{header.Origin} == "https://localhost" || {header.Origin} == "https://localhost:443" || {header.Origin} == "https://127.0.0.1" || {header.Origin} == "https://127.0.0.1:443" || {header.Origin} == "http://localhost:443" || {header.Origin} == "http://127.0.0.1:443" || {header.Origin} == "http://localhost:3000" || {header.Origin} == "http://127.0.0.1:3000" || {header.Origin} == "https://7f6540pm-443.euw.devtunnels.ms" || {header.Origin} == "https://kergit.com"`
  }
  handle @livekitAllowedPreflight {
    header {
      import livekit_cors_headers
    }
    respond "" 204
  }

  @livekitPreflight {
    path /livekit*
    method OPTIONS
  }
  respond @livekitPreflight 403

  @preflight method OPTIONS
  respond @preflight 204

  # Admin/control panel routes are LAN-only (blocked from public internet).
  @adminDenied {
    path /admin* /admin-api* /admin-livekit-metrics*
    not remote_ip {$ADMIN_ALLOWED_CIDR:private_ranges} 127.0.0.1/8 ::1
  }
  respond @adminDenied 403

  # Admin app metrics from the backend control plane.
  handle_path /admin-api* {
    reverse_proxy {
      to {$ADMIN_CONTROL_TARGET:sercom-dev-ubuntu:8081}
    }
  }

  # Admin app LiveKit Prometheus metrics.
  handle_path /admin-livekit-metrics/node-1* {
    rewrite * /metrics
    reverse_proxy {
      to {$ADMIN_LIVEKIT_NODE1_METRICS_TARGET:livekit-node1:6789}
    }
  }

  handle_path /admin-livekit-metrics/node-2* {
    rewrite * /metrics
    reverse_proxy {
      to {$ADMIN_LIVEKIT_NODE2_METRICS_TARGET:livekit-node2:6790}
    }
  }

  # Nuxt admin frontend (served under /admin)
  # Keep /admin prefix; Nuxt is configured with baseURL=/admin/.
  handle /admin* {
    reverse_proxy {
      to {$ADMIN_APP_TARGET:host.docker.internal:3001}
    }
  }

  # LiveKit signaling → Node 1
  handle_path /livekit-node-1* {
  
    @allowedOrigin {
      expression `{header.Origin} == "https://localhost" || {header.Origin} == "https://localhost:443" || {header.Origin} == "https://127.0.0.1" || {header.Origin} == "https://127.0.0.1:443" || {header.Origin} == "http://localhost:443" || {header.Origin} == "http://127.0.0.1:443" || {header.Origin} == "http://localhost:3000" || {header.Origin} == "http://127.0.0.1:3000" || {header.Origin} == "https://7f6540pm-443.euw.devtunnels.ms" || {header.Origin} == "https://kergit.com"`
    }
  
    @originPresent header Origin *
  
    handle @allowedOrigin {
      header {
        import livekit_cors_headers
      }
      reverse_proxy livekit-node1:7880
    }
  
    handle @originPresent {
      respond 403
    }
  
    reverse_proxy livekit-node1:7880
  }

  # LiveKit signaling → Node 2
  handle_path /livekit-node-2* {

    @allowedOrigin {
      expression `{header.Origin} == "https://localhost" || {header.Origin} == "https://localhost:443" || {header.Origin} == "https://127.0.0.1" || {header.Origin} == "https://127.0.0.1:443" || {header.Origin} == "http://localhost:443" || {header.Origin} == "http://127.0.0.1:443" || {header.Origin} == "http://localhost:3000" || {header.Origin} == "http://127.0.0.1:3000" || {header.Origin} == "https://7f6540pm-443.euw.devtunnels.ms" || {header.Origin} == "https://kergit.com"`
    }

    @originPresent header Origin *

    handle @allowedOrigin {
      header {
        import livekit_cors_headers
      }
      reverse_proxy livekit-node2:7890
    }

    handle @originPresent {
      respond 403
    }

    reverse_proxy livekit-node2:7890
  }

  # Backend WebSocket server
  handle_path /ws* {
    reverse_proxy {
      to sercom-dev-ubuntu:9001
      header_up Host {host}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}
      header_up Origin {http.request.header.Origin}
      header_up X-Forwarded-Origin {http.request.header.Origin}
    }
  }

  # Nuxt frontend
  handle {
    reverse_proxy {
      to host.docker.internal:3000
      header_down Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
      header_down X-Frame-Options "DENY"
      header_down Referrer-Policy "strict-origin-when-cross-origin"
      header_down Permissions-Policy "geolocation=(), camera=(), microphone=(self), usb=(), payment=(), accelerometer=(), gyroscope=(), magnetometer=()"
      header_down Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; frame-src 'self'; form-action 'self' https://xxinxxsxutfkqajbmlar.supabase.co; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://api.dicebear.com; connect-src 'self' https://xxinxxsxutfkqajbmlar.supabase.co wss://kergit.com; worker-src 'self' blob:; media-src 'self' blob:"
    }
  }
}
