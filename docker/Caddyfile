:443 {
  tls /certs/cert.pem /certs/key.pem

  @preflight method OPTIONS
  respond @preflight 204

  # LiveKit signaling (CORS only here)
  handle_path /livekit* {
    header {
      Access-Control-Allow-Origin "{http.request.header.Origin}"
      Access-Control-Allow-Credentials "true"
      Access-Control-Allow-Methods "GET, OPTIONS"
      Access-Control-Allow-Headers "Authorization, Content-Type, X-Room-ID"
    }
    # Browser WebSocket can't set custom headers; derive routing header from query.
    request_header X-Room-ID {query.room_id}

    reverse_proxy {
      to 127.0.0.1:7880
      to 127.0.0.1:7890
      lb_policy header X-Room-ID
    }
  }

  # Backend WebSocket server
  handle_path /ws* {
    reverse_proxy {
      to 127.0.0.1:9001
      to 127.0.0.1:9002
      lb_policy least_conn
      header_up Host {host}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}
      header_up Origin {http.request.header.Origin}
      header_up X-Forwarded-Origin {http.request.header.Origin}
    }
  }

  # Nuxt frontend
  handle {
    reverse_proxy {
      to 127.0.0.1:3000
      header_down Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
      header_down X-Frame-Options "DENY"
      header_down Referrer-Policy "strict-origin-when-cross-origin"
      header_down Permissions-Policy "geolocation=(), camera=(), microphone=(self), usb=(), payment=(), accelerometer=(), gyroscope=(), magnetometer=()"
      header_down Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; frame-src 'self'; form-action 'self' https://xxinxxsxutfkqajbmlar.supabase.co; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://api.dicebear.com; connect-src 'self' https://xxinxxsxutfkqajbmlar.supabase.co wss:; worker-src 'self' blob:; media-src 'self' blob:"
    }
  }
}
